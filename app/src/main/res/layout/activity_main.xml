<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="AI陪伴助手"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FF6200EE" />

    <ImageView
        android:id="@+id/ivMicIcon"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="32dp"
        android:src="@android:drawable/ic_btn_speak_now"
        android:background="@drawable/circle_background"
        android:padding="16dp"
        android:contentDescription="Microphone" />

    <Button
        android:id="@+id/btnStartStop"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="开始聆听"
        android:textSize="16sp" />

    <Button
        android:id="@+id/btnSetupApi"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="配置API密钥"
        android:textSize="14sp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    <Button
        android:id="@+id/btnSettings"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="设置"
        android:textSize="14sp"
        style="@style/Widget.MaterialComponents.Button.TextButton" />

    <Button
        android:id="@+id/btnCheckUpdate"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="检查更新"
        android:textSize="14sp"
        style="@style/Widget.MaterialComponents.Button.TextButton" />

    <TextView
        android:id="@+id/tvInstructions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="点击开始聆听即可启动AI陪伴助手"
        android:textSize="14sp"
        android:textColor="#FF666666"
        android:gravity="center"
        android:lineSpacingExtra="4dp" />

    <TextView
        android:id="@+id/tvStatusLog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:padding="16dp"
        android:background="#E63399FF"
        android:text="等待启动..."
        android:textSize="14sp"
        android:textColor="#FF6200EE"
        android:gravity="center"
        android:minHeight="60dp" />

</LinearLayout>
